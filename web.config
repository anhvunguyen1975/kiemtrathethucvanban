<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <system.webServer>
        <!-- Cho phép module WebSocket hoạt động độc lập ở chế độ chuyển tiếp -->
        <webSocket enabled="true" />
        
        <rewrite>
            <rules>
                <rule name="Streamlit Proxy" stopProcessing="true">
                    <match url="(.*)" />
                    <action type="Rewrite" url="http://127.0.0.1:8501/{R:1}" />
                </rule>
            </rules>
        </rewrite>
    </system.webServer>
</configuration>